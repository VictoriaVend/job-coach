# Base image
FROM python:3.12-slim

# Working directory
WORKDIR /app

# Upgrade pip and add non-root user
RUN pip install --upgrade pip && \
    useradd -m -s /bin/bash appuser

# Create a dummy structure to cache pip dependencies before copying source
COPY pyproject.toml .
RUN mkdir -p src/job_coach && touch src/job_coach/__init__.py
RUN pip install ".[dev,ml,infra]"

# Copy the rest of the project
COPY . /app

# Install local package
RUN pip install --no-deps -e .

# Secure permissions
RUN chown -R appuser:appuser /app
USER appuser

# Set PYTHONPATH for proper imports
ENV PYTHONPATH=/app/src

# Run command
CMD ["uvicorn", "job_coach.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]