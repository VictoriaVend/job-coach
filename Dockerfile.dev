# Base image
FROM python:3.14-slim

# Working directory
WORKDIR /app

# Copy pyproject.toml and src for caching dependency installation layers
COPY pyproject.toml .
COPY src/ ./src

# Upgrade pip and install dependencies
RUN pip install --upgrade pip
RUN pip install ".[dev]"

# Copy the rest of the project (alembic, docker-compose, etc.)
COPY . /app

# Set PYTHONPATH for proper imports
ENV PYTHONPATH=/app/src

# Run command
CMD ["uvicorn", "job_coach.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]